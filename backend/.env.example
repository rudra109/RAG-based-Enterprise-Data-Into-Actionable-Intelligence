# ─── BigQuery ─────────────────────────────────────────────────
BIGQUERY_PROJECT=enterpriseiq-dev
BIGQUERY_DATASET=enterpriseiq_core

# ─── Cloud Storage ────────────────────────────────────────────
GCS_RAW_BUCKET=enterpriseiq-raw-uploads
GCS_PROCESSED_BUCKET=enterpriseiq-processed-docs
GCS_ML_ARTIFACTS_BUCKET=enterpriseiq-ml-artifacts

# ─── Firestore ────────────────────────────────────────────────
FIRESTORE_PROJECT=enterpriseiq-dev

# ─── Pub/Sub ─────────────────────────────────────────────────
PUBSUB_PROJECT=enterpriseiq-dev
PUBSUB_TOPIC_DOCUMENT_INGESTED=enterpriseiq.document.ingested
PUBSUB_TOPIC_ANOMALY_DETECTED=enterpriseiq.anomaly.detected
PUBSUB_TOPIC_PIPELINE_COMPLETED=enterpriseiq.pipeline.completed
PUBSUB_TOPIC_FORECAST_READY=enterpriseiq.forecast.ready

# ─── Redis Cache ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_SECONDS=3600

# ─── ML Service URLs (Developer B internal endpoints) ─────────
ML_SERVICE_BASE_URL=http://localhost:8000
RAG_SERVICE_URL=http://localhost:8001
ANOMALY_SERVICE_URL=http://localhost:8002
FORECAST_SERVICE_URL=http://localhost:8003
AGENT_SERVICE_URL=http://localhost:8004
KG_SERVICE_URL=http://localhost:8005

# ─── API Settings ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
API_WORKERS=4
API_DEBUG=false
API_SECRET_KEY=your_api_secret_key_here

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ─── SendGrid Email ───────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key_here
NOTIFICATION_FROM_EMAIL=noreply@enterpriseiq.com

# ─── Dataflow ─────────────────────────────────────────────────
DATAFLOW_TEMP_LOCATION=gs://enterpriseiq-pipeline-temp/tmp
DATAFLOW_STAGING_LOCATION=gs://enterpriseiq-pipeline-temp/staging

# ─── App Settings ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,https://app.enterpriseiq.com
